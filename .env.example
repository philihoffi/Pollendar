# Discord Bot-Token (aus dem Developer Portal)
DISCORD_TOKEN=dein_discord_bot_token_hier

# Google Calendar ID
CALENDAR_ID=deine_calendar_id_hier

# Pfad zur Service-Account-JSON auf dem Host-System (wird für Docker-Volume benötigt)
# z.B. /volume1/docker/pollendar/service_account.json
CREDENTIALS_SOURCE=

# Pfad zur Service-Account-JSON im Container (Standard: /app/credentials/service_account.json)
CREDENTIALS_PATH=/app/credentials/service_account.json

# Kommagetrennte Discord-User-IDs (leer = alle erlaubt)
ALLOWED_USER_IDS=

# ────────────────────────────────────────────
# Lokale Entwicklung:
#
# 1. Python-Venv erstellen & Abhängigkeiten installieren:
#    python -m venv .venv
#    .venv\Scripts\activate    (Windows)
#    pip install -r requirements.txt
#
# 2. .env ausfüllen (DISCORD_TOKEN, CALENDAR_ID)
#
# 3. service_account.json nach credentials/ kopieren
#
# 4. Bot starten:
#    python -m src
# ────────────────────────────────────────────
#
# Portainer Setup (NAS):
#
# 1. service_account.json aufs NAS legen, z. B.:
#    /volume1/docker/pollendar/service_account.json
#
# 2. Im Portainer Stack als Environment-Variable setzen:
#    CREDENTIALS_SOURCE=/volume1/docker/pollendar/service_account.json
# ────────────────────────────────────────────