# Discord Bot-Token (aus dem Developer Portal)
DISCORD_TOKEN=dein_discord_bot_token_hier

# Google Calendar ID
CALENDAR_ID=deine_calendar_id_hier

# Pfad zur Service-Account-JSON-Datei (im Container)
CREDENTIALS_PATH=/app/credentials/service_account.json

# Kommagetrennte Discord-User-IDs (leer = alle erlaubt)
ALLOWED_USER_IDS=

# ────────────────────────────────────────────
# Portainer Setup:
# Diese Werte NICHT in .env, sondern direkt im
# Portainer Stack unter "Environment variables"
# eintragen. service_account.json als Portainer
# Config "service_account_config" anlegen.
# ────────────────────────────────────────────