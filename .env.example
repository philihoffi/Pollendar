# Discord Bot Token (from the Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Google Calendar ID
CALENDAR_ID=your_calendar_id_here

# Path to service_account.json on the host system (required for Docker volume)
# e.g., /volume1/docker/pollendar/service_account.json
CREDENTIALS_SOURCE=

# Path to service_account.json inside the container (default: /app/credentials/service_account.json)
CREDENTIALS_PATH=/app/credentials/service_account.json

# Comma-separated Discord User IDs (empty = all allowed)
ALLOWED_USER_IDS=